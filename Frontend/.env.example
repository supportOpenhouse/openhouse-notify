# =============================================================================
# NOTIFICATION PANEL — ENVIRONMENT CONFIGURATION
# Copy this file to .env.local and fill in your values
# =============================================================================

# =============================================================================
# DATABASE (NeonDB)
# SAME URLs as backend/.env — copy them exactly, both apps share one database.
#
# DATABASE_URL         → pooled, used at runtime by NextAuth Prisma Adapter
# DATABASE_URL_UNPOOLED → only needed by the backend for migrations; safe to
#                         include here for reference but frontend never uses it
#
# ⚠  Never run "prisma migrate" from the frontend. Use backend/ for migrations.
# =============================================================================
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# =============================================================================
# NEXTAUTH v5
# AUTH_SECRET: generate with: npx auth secret (validated at startup via lib/env/server.ts)
# AUTH_URL: your deployment URL (no trailing slash)
# =============================================================================
AUTH_SECRET=your-32-char-secret-here
AUTH_URL=http://localhost:3000

# =============================================================================
# GOOGLE OAUTH
# Console: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
# =============================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# =============================================================================
# BACKEND API (Express — notification service)
#
# Session cookies are same-origin only. If the panel and API use different
# hosts (e.g. Vercel + Render), use a same-origin public URL plus a rewrite:
#   NEXT_PUBLIC_API_URL=/api/v1
#   BACKEND_PROXY_ORIGIN=https://your-api.onrender.com
# (BACKEND_PROXY_ORIGIN is read at build time for next.config.mjs rewrites.)
#
# Local dev (recommended — cookie auth works):
NEXT_PUBLIC_API_URL=/api/v1
BACKEND_PROXY_ORIGIN=http://localhost:4000
#
# Direct cross-origin URL (no session cookie from the browser — 401 on
# protected routes unless you add a BFF or Bearer flow):
# NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# =============================================================================

# =============================================================================
# OPENHOUSE MAIN BACKEND API (Django — property search proxy)
# OH_API_URL is server-only (used in app/api/property-search/route.ts).
# The browser calls /api/property-search (same origin) → Next.js forwards to Django.
# This avoids CORS entirely. NEXT_PUBLIC_ alias kept as a read-only fallback.
# =============================================================================
OH_API_URL=https://backend-prod-561394753846.asia-south2.run.app/api/v1/oh
NEXT_PUBLIC_OH_API_URL=https://backend-prod-561394753846.asia-south2.run.app/api/v1/oh
