# =============================================================================
# NOTIFICATION PLATFORM — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values. Do not commit real secrets.
# =============================================================================

# Application
NODE_ENV=development
PORT=4000
APP_NAME=notification-platform
API_VERSION=v1

# NextAuth shared secret — MUST match notificationPanel/.env.local AUTH_SECRET exactly.
AUTH_SECRET=your-auth-secret-here

# Accept NextAuth session JWE via Authorization: Bearer (default true). Set false if unused.
AUTH_ALLOW_SESSION_BEARER=true

# Optional — only for `npm run db:seed`. Min 8 characters. Never commit a real value.
# ADMIN_SEED_PASSWORD=

# =============================================================================
# DATABASE (NeonDB)
# =============================================================================
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# =============================================================================
# REDIS
# =============================================================================
REDIS_URL=rediss://default:your-token@your-host.upstash.io:6379

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=info

# =============================================================================
# Firebase Admin (FCM HTTP v1) — optional until you run push features
# =============================================================================
# Recommended local dev: path to the service account JSON (relative to backend cwd or absolute).
# GOOGLE_APPLICATION_CREDENTIALS=./your-project-firebase-adminsdk-xxxxx.json

# Alternative (e.g. Docker): inline fields from the same JSON (private key must use \n for newlines).
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# One-off test: npm run fcm:test — pass token as argv or set for the command only:
# FCM_DEVICE_TOKEN=

# =============================================================================
# Future
# =============================================================================
# JWT_SECRET=
# JWT_EXPIRES_IN=7d
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100
