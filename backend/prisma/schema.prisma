// =============================================================================
// NOTIFICATION PLATFORM - CANONICAL DATABASE SCHEMA
// Auth models (User, Account, Session) are NextAuth-compatible.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ============================================================
// ENUMS - Auth
// ============================================================

enum Role {
  SUPER_ADMIN
  ADMIN
  MARKETING_MANAGER
  MARKETING_EXECUTIVE
  ANALYST
  VIEWER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
  PENDING_VERIFICATION
}

// ============================================================
// ENUMS - Notifications
// ============================================================

enum NotificationChannel {
  PUSH
  EMAIL
  SMS
  IN_APP
}

enum NotificationStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  FAILED
  CANCELLED
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
  FAILED
}

enum DevicePlatform {
  ANDROID
  IOS
  WEB
}

enum AudienceType {
  ALL_USERS
  SEGMENT
  CUSTOM
}

// ============================================================
// AUTH MODELS (NextAuth-compatible)
// ============================================================

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  image         String?

  // Extended auth fields
  password              String?    // null for OAuth-only users
  role                  Role       @default(VIEWER)
  status                UserStatus @default(ACTIVE)

  // Login metadata
  lastLoginAt         DateTime?
  lastLoginIp         String?
  lastLoginDevice     String?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NextAuth relations
  accounts  Account[]
  sessions  Session[]

  // Platform relations
  devices   Device[]
  auditLogs AuditLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  // Extended session metadata
  ipAddress  String?
  userAgent  String?
  deviceInfo String?
  isRevoked  Boolean  @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// PLATFORM MODELS
// ============================================================

model Device {
  id        String         @id @default(uuid())
  userId    String
  platform  DevicePlatform
  token     String         @unique
  appId     String
  isActive  Boolean        @default(true)
  metadata  Json?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("devices")
}

model Template {
  id        String   @id @default(uuid())
  name      String   @unique
  title     String
  body      String
  imageUrl  String?
  variables Json?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("templates")
}

model Campaign {
  id          String              @id @default(uuid())
  name        String
  description String?
  status      CampaignStatus      @default(DRAFT)
  channel     NotificationChannel @default(PUSH)

  // Notification content
  title       String
  body        String
  imageUrl    String?
  deepLinkUrl String?
  ctaLabel    String?
  silent      Boolean             @default(false)

  // Targeting / delivery metadata
  audienceType     String  @default("csv_tokens")
  platform         String  @default("all")
  priority         String  @default("normal")
  notificationType String  @default("promotional")

  // Firebase topic-based broadcast (e.g. "all-users", "android-users")
  // When set, the dispatch processor sends via topic instead of token multicast.
  fcmTopic         String?

  // Progress counters (updated by FCM batch processor)
  totalCount  Int @default(0)
  sentCount   Int @default(0)
  failedCount Int @default(0)

  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recipients    CampaignRecipient[]
  notifications Notification[]

  @@index([status])
  @@map("campaigns")
}

model CampaignRecipient {
  id         String             @id @default(uuid())
  campaignId String
  token      String
  status     NotificationStatus @default(PENDING)
  sentAt     DateTime?
  failedAt   DateTime?
  errorMsg   String?
  createdAt  DateTime           @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, token])
  @@index([campaignId])
  @@index([campaignId, status])
  @@map("campaign_recipients")
}

model Notification {
  id           String              @id @default(uuid())
  campaignId   String?
  title        String
  body         String
  channel      NotificationChannel
  status       NotificationStatus  @default(PENDING)
  payload      Json?
  sentAt       DateTime?
  deliveredAt  DateTime?
  failedAt     DateTime?
  errorMessage String?
  retryCount   Int                 @default(0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([campaignId])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String?
  resourceId String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
